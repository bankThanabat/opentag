{
  "name": "@opentag/github",
  "version": "0.1.0",
  "description": "GitHub event normalization and callback rendering for OpenTag.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "opentag",
    "github",
    "probot",
    "agents",
    "webhooks"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup && tsc -b tsconfig.json --emitDeclarationOnly --force",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@opentag/client": "workspace:*",
    "hono": "^4.6.15",
    "@opentag/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
