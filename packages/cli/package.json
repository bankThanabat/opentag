{
  "name": "@opentag/cli",
  "version": "0.1.0",
  "description": "OpenTag command line interface.",
  "type": "module",
  "bin": {
    "opentag": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "opentag",
    "cli",
    "agents",
    "lark"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup && tsc -b tsconfig.json --emitDeclarationOnly --force",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@opentag/client": "workspace:*",
    "@opentag/core": "workspace:*",
    "@opentag/github": "workspace:*",
    "@opentag/lark": "workspace:*",
    "@opentag/local-runtime": "workspace:*",
    "@opentag/slack": "workspace:*",
    "@clack/prompts": "^0.11.0",
    "commander": "^12.1.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@opentag/dispatcher": "workspace:*",
    "@opentag/runner": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
